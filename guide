    .section p{font-size:.9rem;line-height:1.85;margin-bottom:.8rem;color:#333}

    /* 補足ボックス */
    .note{background:var(--pink-light);border-left:4px solid var(--pink);padding:.9rem 1rem;border-radius:0 .4rem .4rem 0;margin:1rem 0;font-size:.85rem;line-height:1.8}
    .note-label{font-weight:700;color:var(--pink);font-size:.75rem;letter-spacing:.05em;margin-bottom:.3rem}

    /* リンクカード */
    .link-card{display:block;text-decoration:none;color:var(--text);border:1px solid var(--border);border-radius:.5rem;padding:.9rem 1rem;margin:.8rem 0;transition:background .15s,border-color .15s}
    .link-card:hover{background:var(--pink-bg);border-color:var(--pink)}
    .link-card-name{font-weight:700;font-size:.9rem;margin-bottom:.15rem}
    .link-card-url{font-size:.7rem;color:#999}

    /* ルール箇条 */
    .rule-list{list-style:none;margin:.8rem 0}
    .rule-list li{position:relative;padding:.5rem 0 .5rem 1.4rem;font-size:.88rem;line-height:1.7;border-bottom:1px solid #f0f0f0}
    .rule-list li::before{content:"";position:absolute;left:0;top:.85rem;width:.55rem;height:.55rem;background:var(--pink);border-radius:50%;opacity:.6}

    /* 強調テキスト */
    .emphasis{background:var(--pink-bg);border-radius:.5rem;padding:1.2rem;margin:1.2rem 0;text-align:center;font-size:.95rem;line-height:1.8;font-weight:600;color:var(--pink)}

    /* トップへ戻るリンク */
